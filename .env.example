# Copy to `.env` in this directory (same folder as package.json). Do not commit `.env`.
# Values already set in the real environment are left unchanged (shell wins over .env).

# Required for Honeycomb ingest
HONEYCOMB_API_KEY=

# Optional — default in code is claude-code
# HONEYCOMB_DATASET=claude-code

# Optional — default is Honeycomb’s OTLP/HTTP traces URL (override for EU, Refinery proxy, etc.)
# HONEYCOMB_OTLP_TRACES_ENDPOINT=https://api.honeycomb.io/v1/traces

# Optional — alternate env file (absolute path, or path relative to this package root)
# CLAUDE_OTEL_DOTENV_PATH=/path/to/.env.claude-otel

# OpenTelemetry GenAI semantic conventions (optional; hooks JSON usually has no model name)
# https://opentelemetry.io/docs/specs/semconv/gen-ai/
# CLAUDE_OTEL_GEN_AI_PROVIDER=anthropic
# CLAUDE_OTEL_GEN_AI_MODEL=claude-sonnet-4-20250514

# Optional — record gen_ai.input.messages / gen_ai.output.messages (JSON strings; HIGHLY SENSITIVE)
# https://opentelemetry.io/docs/specs/semconv/gen-ai/gen-ai-spans/#recording-content-on-attributes
# CLAUDE_OTEL_RECORD_GEN_AI_MESSAGES=true
# CLAUDE_OTEL_RECORD_GEN_AI_INPUT_MESSAGES=true
# CLAUDE_OTEL_RECORD_GEN_AI_OUTPUT_MESSAGES=true
# CLAUDE_OTEL_GEN_AI_MESSAGE_MAX_CHARS=32768
